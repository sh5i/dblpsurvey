#!/bin/bash

PROFILE=default
BIBTEX=0
INSERT=""
KEY_FILTER=(cat)
DOI_FILTER=(cat)
while getopts kdp:bi: OPT; do
  case $OPT in
    k) KEY_FILTER=(perl -pe 's/^[^ ]+ //') ;;
    d) DOI_FILTER=(perl -pe 's/ [^ ]*\n$/\n/') ;;
    p) PROFILE=$OPTARG ;;                  # search the data/<PROFILE>.txt.gz text DB
    b) BIBTEX=1 ;;                         # emit the picks as BibTeX to stdout
    i) INSERT=$OPTARG ;;                   # insert the picks (as BibTeX) into the given .bib
    *) exit 1 ;;
  esac
done
shift $((OPTIND - 1))

here="$(dirname "$(realpath "$0")")"

query="$*"

# fzf > peco > grep
if type fzf >/dev/null 2>&1 ; then
  PICKER=(fzf -i --ansi --multi --no-sort --layout=reverse-list --query="$query")
elif type peco >/dev/null 2>&1; then
  PICKER=(peco --layout=bottom-up --query="$query")
else
  PICKER=(grep -i -- "$query")
fi

# pbcopy > xsel > putclip
if type pbcopy >/dev/null 2>&1; then
  PBCOPY=(pbcopy)
elif type xsel >/dev/null 2>&1 ; then
  PBCOPY=(xsel --input --clipboard)
elif type putclip >/dev/null 2>&1 ; then
  PBCOPY=(putclip)
else
  PBCOPY=(true)
fi

db="$here/../data/${PROFILE}.txt.gz"
if [ ! -f "$db" ]; then
  echo "dblpsurvey: $db not found; run 'make PROFILE=$PROFILE' first." >&2
  exit 1
fi

selection=$(gunzip -c "$db" | "${PICKER[@]}")
# Don't clobber the clipboard when nothing was selected (e.g. aborted with ESC).
[ -n "$selection" ] || exit 0

# -b / -i: serialise the picks to BibTeX (dblpcite, via the dblp.db domain layer).  -b prints
# them to stdout; -i FILE inserts them into FILE with bibgraft (preserving its conventions).
if [ "$BIBTEX" = 1 ] || [ -n "$INSERT" ]; then
  bibtex=$(printf '%s\n' "$selection" | "$here/dblpcite" --profile "$PROFILE") || exit 1
  [ -n "$bibtex" ] || exit 0
  if [ -n "$INSERT" ]; then
    printf '%s' "$bibtex" | python3 "$here/../src/bibgraft.py" "$INSERT" --insert
  else
    printf '%s' "$bibtex"
  fi
  exit 0
fi

printf '%s\n' "$selection" \
  | "${KEY_FILTER[@]}" \
  | "${DOI_FILTER[@]}" \
  | tee >(perl -pe 's/\e\[[;\d]*m//g' | "${PBCOPY[@]}")
