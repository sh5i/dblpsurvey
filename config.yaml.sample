journals:
  # IEEE Transactions on Software Engineering
  - tse
  # ACM Transactions on Software Engineering and Methodology
  - tosem

conferences:
  # International Conference on Software Engineering
  - icse
  # Foundations of Software Engineering
  - sigsoft
  # Automated Software Engineering (ASE / KBSE)
  - kbse

year:
  lower: 2005
  upper: 2100

# Optional: DBLP <article> only carries the ISO-4 abbreviation.
# Map abbreviation -> full title here and it is registered into the SQLite database at build time.
journal_names:
  "IEEE Trans. Software Eng.": "IEEE Transactions on Software Engineering"
  "ACM Trans. Softw. Eng. Methodol.": "ACM Transactions on Software Engineering and Methodology"
